GOLF_COURSE_API_KEY=your_api_key_here
DATABASE_URL=sqlite:///./data/golf.db

# JWT signing secret — must be a random string of at least 32 characters
JWT_SECRET=change-me-set-a-long-random-string-here

# Admin credentials — ADMIN_PASSWORD_HASH is a bcrypt hash of the admin password
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Google OAuth client ID
GOOGLE_CLIENT_ID=your-google-client-id-here
